# server
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development
CORS_ORIGINS=http://localhost:8000,http://localhost:3000

# owner (куда падают уведомления о заявках)
OWNER_EMAIL=you@example.com
OWNER_NAME=Konstantin

# smtp (Yandex)
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your_login@yandex.ru
SMTP_PASSWORD=app_password_here
SMTP_FROM=your_login@yandex.ru
SMTP_USE_TLS=true

# rate limit
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_SECONDS=600

# email через HTTP (приоритетнее SMTP, если задан ключ)
# Нужно для хостингов, режущих исходящий SMTP (Render Free и т.п.)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev

# ai (OpenRouter, OpenAI-совместимый API)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=http://localhost:8000
OPENROUTER_APP_TITLE=Developer Landing
AI_TIMEOUT_SECONDS=10
